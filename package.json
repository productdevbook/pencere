{
  "name": "pencere",
  "version": "0.0.1",
  "description": "Modern, accessible, framework-agnostic lightbox — pure TypeScript, zero dependencies, ESM, tree-shakeable.",
  "keywords": [
    "a11y",
    "accessible",
    "dialog",
    "esm",
    "gallery",
    "image-viewer",
    "lightbox",
    "modal",
    "pencere",
    "photo",
    "tree-shakeable",
    "typescript",
    "zero-dependency",
    "zoom"
  ],
  "homepage": "https://github.com/productdevbook/pencere",
  "bugs": {
    "url": "https://github.com/productdevbook/pencere/issues"
  },
  "license": "MIT",
  "author": "productdevbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/productdevbook/pencere.git"
  },
  "funding": "https://github.com/sponsors/productdevbook",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/adapters/react.d.mts",
      "default": "./dist/adapters/react.mjs"
    },
    "./vue": {
      "types": "./dist/adapters/vue.d.mts",
      "default": "./dist/adapters/vue.mjs"
    },
    "./svelte": {
      "types": "./dist/adapters/svelte.d.mts",
      "default": "./dist/adapters/svelte.mjs"
    },
    "./solid": {
      "types": "./dist/adapters/solid.d.mts",
      "default": "./dist/adapters/solid.mjs"
    },
    "./element": {
      "types": "./dist/adapters/element.d.mts",
      "default": "./dist/adapters/element.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "vitest",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "fmt": "oxfmt .",
    "test": "pnpm lint && pnpm typecheck && vitest run",
    "typecheck": "tsgo --noEmit",
    "size": "size-limit",
    "release": "pnpm test && pnpm build && bumpp --commit --tag --push --all",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.2",
    "bumpp": "^11.0.1",
    "jsdom": "^29.0.2",
    "obuild": "^0.4.33",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "react": "^19.2.5",
    "size-limit": "^12.0.1",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "react": ">=18",
    "solid-js": ">=1.8",
    "svelte": ">=4",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
